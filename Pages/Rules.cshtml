@page
@model Viaproxima.Web.Pages.RulesModel
@{ ViewData["Title"] = "Rules"; }

@section Styles {
    <link rel="stylesheet" href="~/css/vp.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp.base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/characterSheet.layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/floraFauna.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp-tome.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp-tome-lore.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/adveniriska.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/regler.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/rules-sidebar.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
}

<div class="page">
    <div class="vp-folio">
            <span class="vp-folio__tick--tr"></span>
            <span class="vp-folio__tick--bl"></span>
            <div class="vp-folio__grid">

                <aside class="vp-sidenav">
                    <div class="vp-sidenav__header">
                        <div class="vp-sidenav__eyebrow">— viaproxima —</div>
                        <div class="vp-sidenav__title">Regler</div>
                    </div>

                    <div class="vp-sidenav__group-wrap">
                        <a class="vp-sidenav__item" data-rules-key="spelarbok">Spelarbok</a>
                    </div>

                    <div class="vp-sidenav__group-wrap">
                        <span class="vp-sidenav__group">LIV &amp; STRID</span>
                        <a class="vp-sidenav__item" data-rules-key="livstrid">Liv &amp; Strid</a>
                    </div>

                    <div class="vp-sidenav__group-wrap">
                        <span class="vp-sidenav__group">ADVENIRES FYRA LÄRDOMAR</span>

                        <div class="vp-sidenav__accordion" data-accordion="kristallsejdare">
                            <a class="vp-sidenav__item vp-sidenav__accordion-toggle" data-rules-key="kristallsejdare">
                                Kristallsejdare <span class="vp-sidenav__chevron">▸</span>
                            </a>
                            <ul class="vp-sidenav__children">
                                <li><a class="vp-sidenav__item" data-rules-key="lore-rod">Läran om Röd Vrede</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lore-gron">Läran om Grön Skam</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lore-gul">Läran om Gul Lycka</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lore-lila">Läran om Lila Stolthet</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lore-orange">Läran om Orange Kärlek</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lore-bla">Läran om Blå Sorg</a></li>
                            </ul>
                        </div>

                        <a class="vp-sidenav__item" data-rules-key="shamaner">Shamaner</a>

                        <div class="vp-sidenav__accordion" data-accordion="lyadskapare">
                            <a class="vp-sidenav__item vp-sidenav__accordion-toggle" data-rules-key="lyadskapare">
                                Lyådskapare <span class="vp-sidenav__chevron">▸</span>
                            </a>
                            <ul class="vp-sidenav__children">
                                <li><a class="vp-sidenav__item" data-rules-key="lyad-kontroll">Kontroll</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lyad-lasning">Läsning</a></li>
                                <li><a class="vp-sidenav__item" data-rules-key="lyad-flykt">Flykt</a></li>
                            </ul>
                        </div>

                        <a class="vp-sidenav__item" data-rules-key="orakel">Orakel</a>
                    </div>
                </aside>

                <main class="rules-content">
                    <div id="panel-spelarbok">
                        @await Html.PartialAsync("_RulesSpelarbok")
                    </div>
                    <div id="panel-livstrid" style="display:none">
                        @await Html.PartialAsync("_RulesLivStrid")
                    </div>
                    <div id="panel-kristallsejdare" style="display:none">
                        @await Html.PartialAsync("_KristallsejdareRegler")
                    </div>
                    <div id="panel-lore-rod" style="display:none">
                        @await Html.PartialAsync("_LoreRod")
                    </div>
                    <div id="panel-lore-gron" style="display:none">
                        @await Html.PartialAsync("_LoreGron")
                    </div>
                    <div id="panel-lore-gul" style="display:none">
                        @await Html.PartialAsync("_LoreGul")
                    </div>
                    <div id="panel-lore-lila" style="display:none">
                        @await Html.PartialAsync("_LoreLila")
                    </div>
                    <div id="panel-lore-orange" style="display:none">
                        @await Html.PartialAsync("_LoreOrange")
                    </div>
                    <div id="panel-lore-bla" style="display:none">
                        @await Html.PartialAsync("_LoreBla")
                    </div>
                    <div id="panel-shamaner" style="display:none">
                        @await Html.PartialAsync("_RulesShamanerNy")
                    </div>
                    <div id="panel-lyadskapare" style="display:none">
                        @await Html.PartialAsync("_RulesLyadskapare")
                    </div>
                    <div id="panel-orakel" style="display:none">
                        @await Html.PartialAsync("_RulesOrakel")
                    </div>
                </main>

                <aside class="vp-toc is-hidden" id="rules-toc">
                    <div class="vp-toc__label">På denna sida</div>
                    <ul class="vp-toc__list"></ul>
                </aside>

            </div>
        </div>
</div>

@section Scripts {
    <script src="~/js/pages/rules.page.js" asp-append-version="true"></script>
}
