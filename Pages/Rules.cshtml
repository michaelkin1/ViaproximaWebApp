@page
@model Viaproxima.Web.Pages.RulesModel
@{ ViewData["Title"] = "Rules"; }

@section Styles {
    <link rel="stylesheet" href="~/css/vp.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp.base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/characterSheet.layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/floraFauna.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
}

<div class="page">
    <div class="sheet sheet--list">
        <header class="sheet-header">
            <div>
                <div class="label">Viaproxima</div>
                <div class="value" id="cardTitle">Rules</div>
            </div>
        </header>

        <section class="sheet-column">
            <div class="tab-bar">
                <button class="tab-btn tab-btn--active" data-tab="spelarbok">Spelarbok</button>
                <button class="tab-btn" data-tab="poangkostnader">Poängkostnader</button>
                <button class="tab-btn" data-tab="laror">Läror</button>
                <button class="tab-btn" data-tab="shamaner">Shamaner</button>
                <button class="tab-btn" data-tab="kristallsejdare">Kristallsejdare</button>
            </div>

            <div class="lore-sub-bar" id="loreSubBar" style="display:none">
                <button class="lore-sub-btn" data-lore="roda"
                    style="--lore-color:#c0392b;--lore-active-bg:#fdf0ee">Röda Vreden</button>
                <button class="lore-sub-btn" data-lore="grona"
                    style="--lore-color:#27ae60;--lore-active-bg:#edfaf1">Gröna Skammen</button>
                <button class="lore-sub-btn" data-lore="gula"
                    style="--lore-color:#d4a017;--lore-active-bg:#fefae9">Gula Lyckan</button>
                <button class="lore-sub-btn" data-lore="lila"
                    style="--lore-color:#7d3c98;--lore-active-bg:#f5eeff">Lila Stoltheten</button>
                <button class="lore-sub-btn" data-lore="orangea"
                    style="--lore-color:#ca6f1e;--lore-active-bg:#fef4ea">Orangea Kärleken</button>
                <button class="lore-sub-btn" data-lore="blaa"
                    style="--lore-color:#2471a3;--lore-active-bg:#eaf4fd">Blåa Sorgen</button>
            </div>

            <div class="tab-content" id="tab-spelarbok">
                <iframe src="/pdfs/Rules/Spelarbok.pdf#toolbar=0&zoom=page-width" class="pdf-iframe"></iframe>
            </div>

            <div class="tab-content" id="tab-poangkostnader" style="display:none;">
                <iframe src="/pdfs/Rules/viaproxima_karaktarsskapande.pdf#toolbar=0&zoom=page-width" class="pdf-iframe"></iframe>
            </div>

            <div class="tab-content" id="tab-laror" style="display:none;">
                <div class="lore-panel" id="lore-roda" style="position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#7a1a0e,#3a0a04);color:#f5c6b0">
                        <span class="lore-banner__dot" style="background:#c0392b"></span>
                        <span class="lore-banner__name">Röda Vreden</span>
                        <span class="lore-banner__sub">— Eld och Rök</span>
                    </div>
                    <iframe src="/pdfs/Lores/RödVrede.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
                <div class="lore-panel" id="lore-grona" style="display:none;position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#0e4a1e,#06200c);color:#a8e6b8">
                        <span class="lore-banner__dot" style="background:#27ae60"></span>
                        <span class="lore-banner__name">Gröna Skammen</span>
                        <span class="lore-banner__sub">— Skog och Skam</span>
                    </div>
                    <iframe src="/pdfs/Lores/GrönSkam.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
                <div class="lore-panel" id="lore-gula" style="display:none;position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#7a5a08,#3a2a02);color:#f5e0a0">
                        <span class="lore-banner__dot" style="background:#d4a017"></span>
                        <span class="lore-banner__name">Gula Lyckan</span>
                        <span class="lore-banner__sub">— Sol och Slump</span>
                    </div>
                    <iframe src="/pdfs/Lores/GulLycka.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
                <div class="lore-panel" id="lore-lila" style="display:none;position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#3a1050,#1a0828);color:#d8b8f0">
                        <span class="lore-banner__dot" style="background:#7d3c98"></span>
                        <span class="lore-banner__name">Lila Stoltheten</span>
                        <span class="lore-banner__sub">— Makt och Majestät</span>
                    </div>
                    <iframe src="/pdfs/Lores/LilaStolthet.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
                <div class="lore-panel" id="lore-orangea" style="display:none;position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#7a3008,#3a1402);color:#f5c890">
                        <span class="lore-banner__dot" style="background:#ca6f1e"></span>
                        <span class="lore-banner__name">Orangea Kärleken</span>
                        <span class="lore-banner__sub">— Värme och Vilja</span>
                    </div>
                    <iframe src="/pdfs/Lores/OrangeKärlek.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
                <div class="lore-panel" id="lore-blaa" style="display:none;position:relative">
                    <div class="lore-banner" style="background:linear-gradient(to right,#0e2a50,#06121e);color:#a0c8f0">
                        <span class="lore-banner__dot" style="background:#2471a3"></span>
                        <span class="lore-banner__name">Blåa Sorgen</span>
                        <span class="lore-banner__sub">— Vatten och Vemod</span>
                    </div>
                    <iframe src="/pdfs/Lores/BlåSorg.pdf#toolbar=0" class="pdf-iframe lore-iframe"></iframe>
                </div>
            </div>
            <div class="tab-content" id="tab-shamaner" style="display:none;">
                <div class="sh-panel">
                    <p class="sh-prose">Shamaner utför ritualer genom att offra ingredienser. I Viaproxima finns vanliga shamanritualer som de flesta shamaner kan lära sig och använda. Shamaner kan även skapa egna ritualer i samråd med spelledaren, så länge de följer samma struktur.</p>

                    <h3 class="sh-section-title">KV och ritualnivåer</h3>
                    <p class="sh-prose"><strong>KV betyder kraftvärde.</strong> När en shaman utför en ritual offrar hen ingredienser och räknar ihop deras KV. Alla shamanritualer har tre effektnivåer:</p>
                    <table class="sh-table">
                        <thead><tr><th>Ritualnivå</th><th>Kräver KV</th></tr></thead>
                        <tbody>
                            <tr><td>Nivå 1</td><td>10+</td></tr>
                            <tr><td>Nivå 2</td><td>20+</td></tr>
                            <tr><td>Nivå 3</td><td>30+</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Shamanen väljer ritual och nivå innan ingredienser offras.</p>

                    <h3 class="sh-section-title">Ingredienser</h3>
                    <p class="sh-prose">Varje ingrediens har typ, raritet och KV.</p>
                    <table class="sh-table">
                        <thead><tr><th>Ikon</th><th>Typ</th><th>Vikt</th><th>Bidrar främst med</th></tr></thead>
                        <tbody>
                            <tr><td><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"></td><td>Växt</td><td>5 per ruta</td><td>rötter, läkning, tillväxt, bindning, levande material</td></tr>
                            <tr><td><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"></td><td>Svamp</td><td>4 per ruta</td><td>sporer, gift, drömmar, hallucinationer, förfall</td></tr>
                            <tr><td><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"></td><td>Djurdel</td><td>3 per ruta</td><td>kropp, blod, instinkt, sinnen, rörelse, styrka</td></tr>
                            <tr><td><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"></td><td>Mineral</td><td>2 per ruta</td><td>skydd, stabilitet, tyngd, minne, barriärer</td></tr>
                            <tr><td><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></td><td>Essens</td><td>1 per ruta</td><td>Advenire, väder, ande, element, avvikelse</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Ingredienskravet visar minsta antal ingredienser av varje typ. VSE betyder minst en Växt, en Svamp och en Essens.</p>
                    <table class="sh-table">
                        <thead><tr><th>Raritet</th><th>KV</th></tr></thead>
                        <tbody>
                            <tr><td>Vanlig</td><td>3</td></tr>
                            <tr><td>Ovanlig</td><td>6</td></tr>
                            <tr><td>Sällsynt</td><td>9</td></tr>
                            <tr><td>Mytisk</td><td>15</td></tr>
                        </tbody>
                    </table>

                    <h3 class="sh-section-title">Att utföra en ritual</h3>
                    <ol class="sh-list">
                        <li>Välj ritual.</li>
                        <li>Välj ritualnivå.</li>
                        <li>Uppfyll ritualens ingredienskrav.</li>
                        <li>Lägg till extra ingredienser vid behov.</li>
                        <li>Räkna totalt KV.</li>
                        <li>Om KV når vald nivå lyckas ritualen.</li>
                    </ol>
                    <p class="sh-prose">Alla offrade ingredienser förbrukas. Om ritualen avbryts eller inte når vald KV-nivå förbrukas ingredienserna ändå. Spelledaren kan låta en nästan lyckad ritual fungera på lägre nivå eller ge en svagare effekt.</p>

                    <h3 class="sh-section-title">Tidsåtgång</h3>
                    <table class="sh-table">
                        <thead><tr><th>Tidsåtgång</th><th>Betydelse</th></tr></thead>
                        <tbody>
                            <tr><td>Omedelbar</td><td>Effekten sker direkt när ingredienserna offras.</td></tr>
                            <tr><td>1 runda</td><td>Shamanen använder sin runda till att utföra ritualen.</td></tr>
                            <tr><td>2 rundor</td><td>Shamanen måste fokusera i två rundor.</td></tr>
                            <tr><td>3 rundor</td><td>Shamanen måste fokusera i tre rundor.</td></tr>
                            <tr><td>5 rundor</td><td>Tung stridsritual. Kräver att gruppen skyddar shamanen.</td></tr>
                            <tr><td>10 minuter</td><td>Fältritual, platsritual eller undersökning.</td></tr>
                            <tr><td>30 minuter</td><td>Stor ritual, lägerbeskydd eller återställning.</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Om shamanen tar skada, blir fasthållen, tystad, omkullkastad eller brutalt flyttad under en pågående ritual avbryts den.</p>

                    <h3 class="sh-section-title">Ritualpaket</h3>
                    <p class="sh-prose">Vissa ritualer skapar ritualpaket, till exempel salvor, brygder, sporpåsar, rotknyten eller medicinbollar.</p>
                    <p class="sh-prose">Ett ritualpaket skapas genom att ritualen utförs i förväg. Ingredienserna förbrukas när paketet skapas. Paketet räknas sedan som ett föremål och kan användas enligt ritualens effekt.</p>
                    <p class="sh-prose">Oanvända ritualpaket tappar kraft efter nästa fulla vila, om inte ett särskilt föremål bevarar dem.</p>

                    <h3 class="sh-section-title">Dagliga ingredienser</h3>
                    <p class="sh-prose">Varje dag får shamanen en grundmängd ingredienser. Typen bestäms av spelledaren utifrån miljö, tillgång och shamanens metod.</p>
                    <table class="sh-table">
                        <thead><tr><th>Shamannivå</th><th>Dagliga ingredienser</th></tr></thead>
                        <tbody>
                            <tr><td>Nivå 1</td><td>2 Vanliga, 1 Ovanlig</td></tr>
                            <tr><td>Nivå 2</td><td>3 Vanliga, 2 Ovanliga</td></tr>
                            <tr><td>Nivå 3</td><td>2 Ovanliga, 1 Sällsynt</td></tr>
                            <tr><td>Nivå 4</td><td>1 Ovanlig, 3 Sällsynta</td></tr>
                            <tr><td>Nivå 5</td><td>3 Sällsynta, 1 Mytisk</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Ingredienser kan sparas så länge de får plats i inventoryt. Nivå 5-shamaner är mycket starka — de kan regelbundet utföra ritualer på hög nivå, särskilt om de har sparat rätt ingredienser eller skördat extra material.</p>

                    <h3 class="sh-section-title">Skördning</h3>
                    <p class="sh-prose">En shaman kan skörda extra ingredienser genom att leta, samla, jaga, skära, torka, krossa eller fånga ritualmaterial. Shamanen får göra ett antal skördningar per dag lika med sin shamannivå.</p>
                    <table class="sh-table">
                        <thead><tr><th>D100</th><th>Raritet</th></tr></thead>
                        <tbody>
                            <tr><td>1–50</td><td>Vanlig</td></tr>
                            <tr><td>51–84</td><td>Ovanlig</td></tr>
                            <tr><td>85–99</td><td>Sällsynt</td></tr>
                            <tr><td>100</td><td>Mytisk</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Spelledaren bestämmer ingredienstyp utifrån miljö. Skog ger ofta Växt, Svamp och Djurdel. Berg ger ofta Mineral. Magiska avvikelser kan ge Essens.</p>

                    <h3 class="sh-section-title">Egna ritualer</h3>
                    <p class="sh-prose">Spelare kan skapa egna ritualer tillsammans med spelledaren. En egen ritual ska ha:</p>
                    <table class="sh-table">
                        <thead><tr><th>Del</th><th>Innehåll</th></tr></thead>
                        <tbody>
                            <tr><td>Namn</td><td>Ritualens namn</td></tr>
                            <tr><td>Ingredienstyp</td><td>Vilka ingredienser som krävs</td></tr>
                            <tr><td>Tidsåtgång</td><td>Hur lång tid ritualen tar</td></tr>
                            <tr><td>Ritualoutput</td><td>Direkt effekt, ritualpaket, salva, zonritual, platsritual, etc.</td></tr>
                            <tr><td>Nivå 1</td><td>Effekt vid KV 10+</td></tr>
                            <tr><td>Nivå 2</td><td>Effekt vid KV 20+</td></tr>
                            <tr><td>Nivå 3</td><td>Effekt vid KV 30+</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Egna ritualer ska inte vara starkare än en känd ritual med liknande krav och tidsåtgång.</p>

                    <h3 class="sh-section-title">Shamanritualer</h3>
                    <div class="sh-wide-table-wrap">
                        <table class="sh-table sh-rituals-table">
                            <thead>
                                <tr>
                                    <th>Namn</th>
                                    <th>Ingredienstyp</th>
                                    <th>Tid</th>
                                    <th>Ritualoutput</th>
                                    <th>Nivå 1, KV 10+</th>
                                    <th>Nivå 2, KV 20+</th>
                                    <th>Nivå 3, KV 30+</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>Rovdjursryck</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"></span></td>
                                    <td>Omedelbar</td>
                                    <td>Direkt kroppsbuff</td>
                                    <td>Ett mål får ett djuriskt ryck och kan hoppa undan, resa sig, bryta grepp, kasta sig över ett hinder eller klättra några meter.</td>
                                    <td>Som Nivå 1, men målet får +1 HV på handlingen och kan dra med en villig allierad eller ett lätt föremål.</td>
                                    <td>Målet ignorerar även ett mindre fysiskt hinder under handlingen, till exempel lera, snår, smärta eller dåligt fotfäste.</td>
                                </tr>
                                <tr>
                                    <td>Kräksporer</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"></span></td>
                                    <td>Omedelbar</td>
                                    <td>Kastad sporpåse</td>
                                    <td>Ett mål hostar, hulkar eller blinkar och kan inte ropa order, sjunga, hålla talbaserad koncentration eller kasta talbound magi resten av rundan.</td>
                                    <td>Påverkar upp till tre mål nära varandra, eller skapar en liten hostzon vid en passage.</td>
                                    <td>Skapar ett spormoln i en liten zon under en runda. Den som passerar måste sakta ner, hålla andan och tappa tal, eller hosta högt.</td>
                                </tr>
                                <tr>
                                    <td>Benhård Hud</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"></span></td>
                                    <td>Omedelbar</td>
                                    <td>Direkt skydd</td>
                                    <td>Ett mål får hårdnad hud, päls, bark eller skal tills nästa träff. Första Låg-skadan minskas ett steg eller stoppas.</td>
                                    <td>Skyddet varar en scen och kan minska en träff upp till Mellan skada ett steg. Efter träffen spricker skyddet.</td>
                                    <td>Skyddet kan läggas på två mål, eller på ett mål som får stoppa en Hög-träff en gång genom att skyddet krossas.</td>
                                </tr>
                                <tr>
                                    <td>Rotknyte</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"></span></td>
                                    <td>1 runda</td>
                                    <td>Ritualpaket, snara</td>
                                    <td>Skapar ett rotknyte. Vid aktivering håller det fast ett litet föremål, en fot, ett vapenhandtag, en dörregel eller ett hjul i en runda.</td>
                                    <td>Knytet håller fast ett normalt mål tills det använder en handling för att slita sig loss, eller blockerar en smal passage under en kort scen.</td>
                                    <td>Knytet skapar en rotfälla. Första målet som rusar igenom fastnar; andra måste sakta ner, ta omväg eller rensa rötterna.</td>
                                </tr>
                                <tr>
                                    <td>Sårslutarsalva</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"></span></td>
                                    <td>1 runda</td>
                                    <td>Ritualpaket, salva</td>
                                    <td>Skapar en salva som stoppar blödning, stänger ett ytligt sår eller stabiliserar en döende person tills scenen är över.</td>
                                    <td>Salvan får ett brutet ben, sprucken klo, trasigt rep, skadad sköld eller naturföremål att fungera under en scen.</td>
                                    <td>Salvan låter ett svårt skadat mål agera nästan normalt under en scen. Efteråt återkommer skadan och måste behandlas.</td>
                                </tr>
                                <tr>
                                    <td>Rotblixt</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>1 runda</td>
                                    <td>Direkt växtrite</td>
                                    <td>En rot, gren, ranka, spricka eller växtfiber rör sig snabbt och skapar ett handtag, en snubbelpunkt, krok eller liten öppning.</td>
                                    <td>Växtligheten kan flytta ett lätt föremål, dra undan ett hinder, fälla ett mål som rusar eller skapa en kort flyktöppning.</td>
                                    <td>En kort linje av växtlighet reagerar under rundan: öppnar väg, slår undan små hinder eller binder första målet som korsar linjen.</td>
                                </tr>
                                <tr>
                                    <td>Mardrömsspor</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>1 runda</td>
                                    <td>Sporpåse, sinnesstörning</td>
                                    <td>Ett mål ser något kort som inte finns och tappar riktning, fokus eller timing resten av rundan.</td>
                                    <td>Skapar en liten hallucinationszon där ljud, skuggor eller rörelser feltolkas under scenen.</td>
                                    <td>Ett mål eller en liten grupp måste välja: blunda och sakta ner, flytta fel, eller avslöja vad de fruktar genom sin reaktion.</td>
                                </tr>
                                <tr>
                                    <td>Myrögon</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"></span></td>
                                    <td>2 rundor</td>
                                    <td>Sensorisk kropprite</td>
                                    <td>Målet får ett valt djursinne under en scen: lukta blod/svett, höra små rörelser, se i svagt ljus, känna vibrationer eller upptäcka färsk närvaro.</td>
                                    <td>Målet kan följa ett färskt spår trots mörker, regn, trängsel eller lätt maskering. Spåret måste vara högst ett dygn gammalt.</td>
                                    <td>Målet kan dela sinnen med ett litet djur, en insektsvärm eller kadaverätare i området i några minuter.</td>
                                </tr>
                                <tr>
                                    <td>Giftväxling</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"></span></td>
                                    <td>2 rundor</td>
                                    <td>Ritualpaket, brygd/salva</td>
                                    <td>Skapar en dos som antingen bedövar smärta under en scen eller gör ett sår brännande så målet får svårt att fokusera resten av rundan.</td>
                                    <td>Skapar två doser: en motgiftssalva mot vanligt gift och en svag gift- eller bedövningsdos.</td>
                                    <td>Skapar en stark dos som kan söva ett litet mål, förläma en kroppsdel kort eller neutralisera ett allvarligt naturligt gift.</td>
                                </tr>
                                <tr>
                                    <td>Klorna Vaknar</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"></span></td>
                                    <td>2 rundor</td>
                                    <td>Kropprite</td>
                                    <td>Målets händer, fötter, klor eller tänder får djurisk funktion under scenen: klättra, gräva, hålla fast, riva upp mjukt material eller greppa större mål.</td>
                                    <td>Målet får välja två funktioner och får +1 HV när de används.</td>
                                    <td>Målet går in i rovdjursläge under scenen: kan klättra, riva, hålla fast och rusa kort. Efter scenen blir målet utmattat eller hungrigt.</td>
                                </tr>
                                <tr>
                                    <td>Rökande Buk</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>2 rundor</td>
                                    <td>Rökpåse, zonrite</td>
                                    <td>Skapar rök, dimma, kyla, värme eller stark lukt runt en liten plats.</td>
                                    <td>Röken fyller en mindre zon. Den döljer rörelse, bryter siktlinjer, stör luktspår eller tvingar fiender att byta position.</td>
                                    <td>Röken rör sig långsamt i vald riktning under scenen och bär en vald egenskap: kall, varm, illaluktande, söande, stickande eller vilseledande.</td>
                                </tr>
                                <tr>
                                    <td>Blodlock</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"></span></td>
                                    <td>3 rundor</td>
                                    <td>Lockbete, doftrite</td>
                                    <td>Lockar smådjur, insekter eller fåglar till en plats inom några minuter.</td>
                                    <td>Påverkar ett normalt djur eller en mindre flock: lockar bort, samlar, oroar, blockerar väg eller drar uppmärksamhet.</td>
                                    <td>Skapar en stark instinktiv signal i området: fly, samlas, jaga, vakta, äta eller gömma sig.</td>
                                </tr>
                                <tr>
                                    <td>Rötvatten</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>3 rundor</td>
                                    <td>Frätande brygd</td>
                                    <td>Mjukar upp rep, läder, trä, bark, tyg, kött, svamp eller växtmaterial så det kan böjas, skäras, grävas i eller knytas om.</td>
                                    <td>Försvagar en vald del av en större sak, exempelvis repfäste, dörkant, burvägg, sköldrem eller vagnshjul. Nästa försök att bryta den får +2 HV.</td>
                                    <td>Försvagar en större naturlig struktur under scenen. Gruppen kan skapa öppning, sänka skydd eller förstöra hinder om de agerar innan effekten torkar.</td>
                                </tr>
                                <tr>
                                    <td>Fröväg</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>3 rundor</td>
                                    <td>Växtrite, väg</td>
                                    <td>Skapar små handtag, fotfästen, lianer eller mjuka landningspunkter på naturliga ytor.</td>
                                    <td>Skapar en kort passage genom tät vegetation, lera, sprickor, trädrötter eller snår. Gruppen kan passera utan att fastna eller skadas.</td>
                                    <td>Skapar en tydlig rutt genom farlig terräng under scenen, exempelvis träsk, törne, rasbrant eller rotkaos. Rutten vissnar efteråt.</td>
                                </tr>
                                <tr>
                                    <td>Skalbrott</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"></span></td>
                                    <td>3 rundor</td>
                                    <td>Försvagningsrite</td>
                                    <td>Markerar en svag punkt i skal, ben, trä, sten, horn, rustning eller naturligt pansar. Nästa träff eller verktygshandling mot punkten får +1 HV.</td>
                                    <td>Den markerade punkten kan brytas upp av nästa lyckade träff eller verktygshandling.</td>
                                    <td>Shamanen markerar tre punkter på samma mål eller struktur. Om gruppen angriper dem under scenen kan de öppna, fälla, spräcka eller avvapna något hårt.</td>
                                </tr>
                                <tr>
                                    <td>Djuprot</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>5 rundor</td>
                                    <td>Platsrite, förankring</td>
                                    <td>Ett föremål eller en kropp blir rotfast och kan inte enkelt dras, flyttas eller vältas under scenen.</td>
                                    <td>En liten zon blir stabil: föremål står fast, dörrar slår inte upp, lösa stenar rör sig inte och rusande varelser måste sakta ner.</td>
                                    <td>En större varelse, struktur eller passage förankras, exempelvis en bjälke, port, bro eller ritualplats.</td>
                                </tr>
                                <tr>
                                    <td>Stenandning</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>5 rundor</td>
                                    <td>Barriärrite</td>
                                    <td>Förseglar en spricka, liten öppning, behållare, dörkant eller passage med sten, lera, ben eller fossilskal.</td>
                                    <td>Skapar en barriär, kil, provisorisk dörr, stödpelare eller väggdel som stoppar rörelse eller skyddar från en riktning.</td>
                                    <td>Bygger om en mindre plats under scenen: stänger två öppningar, skapar skydd från två håll eller förstärker en kollapsande plats.</td>
                                </tr>
                                <tr>
                                    <td>Spordröm</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"></span></td>
                                    <td>10 minuter</td>
                                    <td>Platsrite, vision</td>
                                    <td>Sporer visar senaste tydliga rörelse genom platsen: riktning, storlek, tempo och om målet var skadat, stressat eller jagat.</td>
                                    <td>Shamanen ser ett kort drömfragment från platsen, några sekunder långt.</td>
                                    <td>Sporerna följer ett förstört eller avbrutet spår och visar målets nästa tydliga stopp som drömbild.</td>
                                </tr>
                                <tr>
                                    <td>Askminne</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>10 minuter</td>
                                    <td>Minnesrite</td>
                                    <td>Läser rester från eld, aska, ben, jord, blod, krossad sten eller förstört material och visar vad som senast rörde eller förstörde det.</td>
                                    <td>Visar en tydligare sekvens från platsen: första våldhandlingen, sista personen som lämnade, föremålet som saknas eller farans riktning.</td>
                                    <td>Återskapar platsens viktigaste händelse som kort syn, doft, ljud och känsla för hela gruppen.</td>
                                </tr>
                                <tr>
                                    <td>Vädermun</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Mushroom.svg" alt="S"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>10 minuter</td>
                                    <td>Väderrite</td>
                                    <td>Shamanen ändrar en liten vädereffekt under en scen: dimma tjocknar, vind vänder, regn dämpat ljud eller hetta/köld mildras.</td>
                                    <td>Vädret blir ett verktyg: rök blåser åt valt håll, regn släcker små lågor, dimma döljer gruppen eller vind bär bort doft.</td>
                                    <td>Shamanen skapar ett kraftigt lokalt väderbrott under scenen: stormpust, tung dimma, iskall vind, hetta, skyfall eller tryckförändring.</td>
                                </tr>
                                <tr>
                                    <td>Jordmoder</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>30 minuter</td>
                                    <td>Stor platsrite</td>
                                    <td>Skapar en skyddad viloplats: torr mark, mild värme, mindre vind och smådjur håller avstånd.</td>
                                    <td>Lägret döljs från enkla spår, lukt och insyn. Väder, smådjur och vanlig nattlig oro hålls ute tills gryning.</td>
                                    <td>Platsen blir en tillfällig helgedom. Skadade stabiliseras bättre, sömn ger starkare återhämtning och fiender känner motvilja att gå in.</td>
                                </tr>
                                <tr>
                                    <td>Återgång</td>
                                    <td><span class="sh-icon-row"><img class="sh-icon" src="/IconsShaman/Plants.svg" alt="V"><img class="sh-icon" src="/IconsShaman/Animal.svg" alt="D"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Mineral.svg" alt="M"><img class="sh-icon" src="/IconsShaman/Essence.svg" alt="E"></span></td>
                                    <td>30 minuter</td>
                                    <td>Återställningsrite</td>
                                    <td>Bryter en mindre kroppslig, naturlig eller advenirisk förändring som nyligen skett.</td>
                                    <td>Återställer ett mål, djur, föremål eller naturmaterial till en tidigare stabil form under en scen.</td>
                                    <td>Stabiliserar en kraftig förvandling, förbannelse eller advenirisk avvikelse. Den tas inte alltid bort permanent, men stoppas från att förvärras.</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="tab-content" id="tab-kristallsejdare" style="display:none;">
                <div class="sh-panel">
                    <p class="sh-prose">Kristallsejdare kanaliserar Advenire genom starka känslor. De använder lärorna, där varje lära är kopplad till en känsla, en färg och ett magiskt uttryck.</p>
                    <p class="sh-prose">Varje lära innehåller:</p>
                    <table class="sh-table">
                        <thead><tr><th>Innehåll</th><th>Antal</th></tr></thead>
                        <tbody>
                            <tr><td>Signaturbesvärjelse</td><td>1</td></tr>
                            <tr><td>Vanliga besvärjelser</td><td>6</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Varje besvärjelse har fem nivåer.</p>

                    <h3 class="sh-section-title">Lärorna</h3>
                    <table class="sh-table">
                        <thead><tr><th>Lära</th><th>Färg</th><th>Känsla</th><th>Uttryck</th></tr></thead>
                        <tbody>
                            <tr><td style="color:#c0392b;font-weight:600">Läran om Röd Vrede</td><td>Röd</td><td>Vrede</td><td>eld, rök, hetta, explosion</td></tr>
                            <tr><td style="color:#27ae60;font-weight:600">Läran om Grön Skam</td><td>Grön</td><td>Skam</td><td>växter, djur, rötter, snår</td></tr>
                            <tr><td style="color:#d4ac0d;font-weight:600">Läran om Gul Glädje</td><td>Gul</td><td>Glädje</td><td>ljus, läkande, värme, livskraft</td></tr>
                            <tr><td style="color:#8e44ad;font-weight:600">Läran om Lila Stolthet</td><td>Lila</td><td>Stolthet</td><td>blixt, nekromanti, dominans</td></tr>
                            <tr><td style="color:#ca6f1e;font-weight:600">Läran om Orange Kärlek</td><td>Orange</td><td>Kärlek</td><td>sten, sand, tyngd, skydd</td></tr>
                            <tr><td style="color:#2980b9;font-weight:600">Läran om Blå Sorg</td><td>Blå</td><td>Sorg</td><td>vatten, vind, kyla, rörelse</td></tr>
                        </tbody>
                    </table>

                    <h3 class="sh-section-title">Kristallsejdarnivå</h3>
                    <p class="sh-prose">En kristallsejdare har nivå 1–5. Kristallsejdaren kan kasta besvärjelser på sin egen nivå eller lägre.</p>
                    <table class="sh-table">
                        <thead><tr><th>Kristallsejdarnivå</th><th>Kan kasta</th></tr></thead>
                        <tbody>
                            <tr><td>Nivå 1</td><td>Nivå 1-besvärjelser</td></tr>
                            <tr><td>Nivå 2</td><td>Nivå 1–2-besvärjelser</td></tr>
                            <tr><td>Nivå 3</td><td>Nivå 1–3-besvärjelser</td></tr>
                            <tr><td>Nivå 4</td><td>Nivå 1–4-besvärjelser</td></tr>
                            <tr><td>Nivå 5</td><td>Nivå 1–5-besvärjelser</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">En kristallsejdare kan inte kasta en besvärjelse på högre nivå än sin egen kristallsejdarnivå.</p>

                    <h3 class="sh-section-title">Dagliga besvärjelser</h3>
                    <p class="sh-prose">Varje dag slår kristallsejdaren ett antal D6 lika med sin kristallsejdarnivå.</p>
                    <table class="sh-table">
                        <thead><tr><th>Kristallsejdarnivå</th><th>Slår varje dag</th></tr></thead>
                        <tbody>
                            <tr><td>Nivå 1</td><td>1D6</td></tr>
                            <tr><td>Nivå 2</td><td>2D6</td></tr>
                            <tr><td>Nivå 3</td><td>3D6</td></tr>
                            <tr><td>Nivå 4</td><td>4D6</td></tr>
                            <tr><td>Nivå 5</td><td>5D6</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Varje siffra motsvarar en av lärans sex vanliga besvärjelser.</p>
                    <table class="sh-table">
                        <thead><tr><th>D6</th><th>Besvärjelse</th></tr></thead>
                        <tbody>
                            <tr><td>1</td><td>Besvärjelse 1</td></tr>
                            <tr><td>2</td><td>Besvärjelse 2</td></tr>
                            <tr><td>3</td><td>Besvärjelse 3</td></tr>
                            <tr><td>4</td><td>Besvärjelse 4</td></tr>
                            <tr><td>5</td><td>Besvärjelse 5</td></tr>
                            <tr><td>6</td><td>Besvärjelse 6</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">De besvärjelser som slås fram är de vanliga besvärjelser kristallsejdaren har tillgång till den dagen.</p>
                    <p class="sh-prose">Om samma siffra slås flera gånger räknas varje extra dublett som ett valfritt val. För varje extra dublett får kristallsejdaren välja en valfri vanlig besvärjelse från samma lära.</p>
                    <p class="sh-prose"><em>Exempel: En nivå 3-kristallsejdare slår 2, 2, 5. Hen får besvärjelse 2 och 5. Eftersom 2 slogs två gånger får hen dessutom välja en valfri vanlig besvärjelse från läran.</em></p>

                    <h3 class="sh-section-title">Signaturbesvärjelse</h3>
                    <p class="sh-prose">Varje lära har en signaturbesvärjelse.</p>
                    <p class="sh-prose">Kristallsejdaren kan alltid byta ut en daglig besvärjelse mot lärans signaturbesvärjelse.</p>
                    <p class="sh-prose">Signaturbesvärjelsen räknas som en vanlig besvärjelse när den kastas och kan ge bakslag och bakslagstryck som vanligt.</p>

                    <h3 class="sh-section-title">Att kasta en besvärjelse</h3>
                    <ol class="sh-list">
                        <li>Välj en tillgänglig besvärjelse från en lära du har tillgång till.</li>
                        <li>Välj vilken nivå av besvärjelsen du kastar.</li>
                        <li>Utför besvärjelsens effekt.</li>
                        <li>Slå 2D6 för bakslag.</li>
                    </ol>
                    <p class="sh-prose">Besvärjelsen sker även om bakslag inträffar, om inte bakslaget förändrar eller avbryter effekten.</p>

                    <h3 class="sh-section-title">Bakslag</h3>
                    <p class="sh-prose">Efter varje kast slår kristallsejdaren 2D6. Om tärningarna visar vissa dubletter sker ett bakslag.</p>
                    <table class="sh-table">
                        <thead><tr><th>Besvärjelsenivå jämfört med kristallsejdaren</th><th>Bakslag sker på</th></tr></thead>
                        <tbody>
                            <tr><td>Samma nivå</td><td>Dubbel 1, dubbel 2 eller dubbel 3</td></tr>
                            <tr><td>1 nivå lägre</td><td>Dubbel 1 eller dubbel 2</td></tr>
                            <tr><td>2 eller fler nivåer lägre</td><td>Dubbel 1</td></tr>
                        </tbody>
                    </table>

                    <h3 class="sh-section-title">Bakslagstryck</h3>
                    <p class="sh-prose">De första tre besvärjelserna en kristallsejdare kastar under en dag ger ingen extra risk.</p>
                    <p class="sh-prose">Efter dagens tredje kast får kristallsejdaren +1 bakslagstryck för varje ytterligare besvärjelse som kastas samma dag. Varje bakslagstryck ökar bakslagsintervallet med en extra dublett.</p>
                    <table class="sh-table">
                        <thead><tr><th>Bakslagstryck</th><th>Ökning</th></tr></thead>
                        <tbody>
                            <tr><td>0</td><td>Ingen ökning</td></tr>
                            <tr><td>1</td><td>+1 dublett</td></tr>
                            <tr><td>2</td><td>+2 dubletter</td></tr>
                            <tr><td>3</td><td>+3 dubletter</td></tr>
                            <tr><td>4+</td><td>Bakslag på alla dubletter</td></tr>
                        </tbody>
                    </table>
                    <p class="sh-prose">Bakslag kan aldrig bli större än alla dubletter, alltså dubbel 1–6. Bakslagstryck försvinner efter en full vila.</p>
                    <p class="sh-prose"><em>Exempel: En nivå 3-kristallsejdare kastar en nivå 2-besvärjelse. Normalt sker bakslag på dubbel 1–2. Om kristallsejdaren har 2 bakslagstryck sker bakslag istället på dubbel 1–4.</em></p>

                    <h3 class="sh-section-title">Bakslagstabell</h3>
                    <p class="sh-prose">När en kristallsejdare får bakslag slår spelaren 2D6 och använder resultatet i tabellen.</p>
                    <div class="sh-wide-table-wrap">
                        <table class="sh-table ks-backlash-table">
                            <thead><tr><th>2D6</th><th>Namn</th><th>Effekt</th></tr></thead>
                            <tbody>
                                <tr><td>2</td><td>Kroppen sviker</td><td>Magikerns kropp förvrids kort av besvärjelsen. Under 1T4 rundor kan magikern bara krypa i halv hastighet och kan inte hoppa, springa eller parera normalt.</td></tr>
                                <tr><td>3</td><td>Ond tvilling</td><td>En mörk version av magikern kliver ut ur hens skugga. Den har samma grundvärden men kan bara använda enkla handlingar. Den attackerar eller saboterar magikern i 3 rundor eller tills den förstörs.</td></tr>
                                <tr><td>4</td><td>Lärans skräck</td><td>Magikern drabbas av intensiv rädsla för lärans uttryck. Under 1T6 rundor vägrar magikern frivilligt gå närmare källan eller kasta samma lära igen.</td></tr>
                                <tr><td>5</td><td>Vänd andning</td><td>Magikerns andning vänder sig inåt. Under 1T3 rundor kan magikern inte tala, sjunga eller kasta besvärjelser som kräver röst. Om hen försöker tar hen 1 skada.</td></tr>
                                <tr><td>6</td><td>Stamskammen</td><td>Magikerns känsla läcker ut socialt. Alla allierade i närheten känner obehag, misstänksamhet eller skam. Under 1T8 rundor får magikern −1 HV på sociala handlingar mot dem.</td></tr>
                                <tr><td>7</td><td>Känslospruta</td><td>Magikerns mun, händer eller ögon läcker lärans kraft under 1T6 rundor. Effekten är liten men farlig: gnistor, sporer, ljus, frost, sand, rök eller vatten. Den kan antända torrt material, avslöja magikern eller störa närliggande föremål.</td></tr>
                                <tr><td>8</td><td>Advenirisk vätska</td><td>En främmande vätska rinner ur magikerns ögon, öron eller mun. Den luktar starkt av lärans känsla. Magikern får −1 HV på precisionshandlingar i 3 rundor.</td></tr>
                                <tr><td>9</td><td>Vänd kognition</td><td>Magikern tror att vän är fiende och hot är trygghet i 1T3 rundor. En allierad kan bryta förvirringen med en lyckad social handling eller genom att fysiskt stoppa magikern.</td></tr>
                                <tr><td>10</td><td>Tungmetall</td><td>Magikerns kläder, kropp och utrustning blir onaturligt tunga. Rörlighet halveras i 1T6 rundor och varje snabb rörelse kräver ett styrkeslag eller motsvarande fysisk handling.</td></tr>
                                <tr><td>11</td><td>Sanningstvång</td><td>Magikern kan bara säga sådant hen själv tror är sant under 1T12 minuter. Att försöka ljuga gör att magikern tappar rösten i en runda.</td></tr>
                                <tr><td>12</td><td>Kosmisk svans</td><td>En lysande svans av advenirisk energi växer ut från magikerns rygg i 1T6 rundor. Varje runda slår den mot ett slumpmässigt mål inom 2 meter och gör låg skada eller skapar en mindre effekt enligt lärans uttryck.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <h3 class="sh-section-title">Besvärjelsenivåer</h3>
                    <p class="sh-prose">Varje besvärjelse har fem nivåer.</p>
                    <table class="sh-table">
                        <thead><tr><th>Besvärjelsenivå</th><th>Typisk omfattning</th></tr></thead>
