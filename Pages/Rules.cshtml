@page
@model Viaproxima.Web.Pages.RulesModel
@{ ViewData["Title"] = "Rules"; }

@section Styles {
    <link rel="stylesheet" href="~/css/vp.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp.base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/characterSheet.layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/floraFauna.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp-tome.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp-tome-lore.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/adveniriska.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/regler.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet">
}

<div class="page">
    <div class="sheet sheet--list">
        <header class="sheet-header">
            <div>
                <div class="label">Viaproxima</div>
                <div class="value" id="cardTitle">Rules</div>
            </div>
        </header>

        <section class="sheet-column">
            <div class="tab-bar">
                <div class="tab-row">
                    <button class="tab-btn" data-tab="spelarbok">Spelarbok</button>
                    <button class="tab-btn" data-tab="poangkostnader">Poängkostnader</button>
                    <button class="tab-btn" data-tab="adveniriska">De fyra Adveniriska lärdomarna</button>
                </div>
                <div class="tab-row">
                    <button class="tab-btn tab-btn--active" data-tab="egenskaper">Egenskaper</button>
                    <button class="tab-btn" data-tab="livstrid">Liv &amp; Strid</button>
                </div>
            </div>

            <div class="tab-content" id="tab-egenskaper">

              <svg width="0" height="0" style="position:absolute" aria-hidden="true">
                <symbol id="vp-tome-filigree-eg" viewBox="0 0 70 70">
                  <g fill="none" stroke="#a8935e" stroke-width="1.2" stroke-linecap="round">
                    <path d="M2 2 L2 36 Q2 18 16 16 Q34 14 36 2" />
                    <path d="M10 2 Q14 10 22 10 Q14 14 14 22 Q10 14 2 14" />
                    <circle cx="14" cy="14" r="1.6" fill="#a8935e" />
                    <path d="M22 2 L22 8" /><path d="M2 22 L8 22" />
                    <path d="M28 4 Q30 8 28 12" /><path d="M4 28 Q8 30 12 28" />
                  </g>
                </symbol>
              </svg>

              <div class="vp-tome">
                <svg class="vp-tome__filigree vp-tome__filigree--tl"><use href="#vp-tome-filigree-eg"/></svg>
                <svg class="vp-tome__filigree vp-tome__filigree--tr"><use href="#vp-tome-filigree-eg"/></svg>
                <svg class="vp-tome__filigree vp-tome__filigree--bl"><use href="#vp-tome-filigree-eg"/></svg>
                <svg class="vp-tome__filigree vp-tome__filigree--br"><use href="#vp-tome-filigree-eg"/></svg>

                <header class="vp-tome__head">
                  <div class="vp-tome__eyebrow">— Viaproxima · Regler —</div>
                  <h1 class="vp-tome__title">Egenskaper</h1>
                  <div class="vp-tome__tagline">Sex grundegenskaper, fyra subegenskaper var. Grundval för alla handlingar i spelet.</div>
                  <div class="vp-tome__divider">
                    <span></span><span class="vp-tome__divider-glyph">❖</span><span></span>
                  </div>
                </header>

                <p><span class="vp-tome__dropcap">D</span>in karaktär har sex grundegenskaper. Varje grundegenskap har fyra subegenskaper som visar vad karaktären mer exakt är bra på. Vid handlingar används oftast grundegenskap + subegenskap.</p>

                <div class="vp-tome__stone">
                  <div class="vp-tome__stone-inner">
                    <span class="vp-tome__stone-text">Testvärde = Grundegenskap + Subegenskap</span>
                  </div>
                </div>

                <div class="vp-tome__card">
                  <div class="vp-tome__card-title">
                    <span class="vp-tome__card-title-glyph">❦</span>
                    <span>Exempel</span>
                  </div>
                  <table class="vp-tome__pair-table">
                    <tbody>
                      <tr>
                        <td>Skjuta med pilbåge</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Skicklighet + Skytte</td>
                      </tr>
                      <tr>
                        <td>Stå emot skräck</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Tålighet + Mental tålighet</td>
                      </tr>
                      <tr>
                        <td>Ljuga trovärdigt</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Utstrålning + Ljuga</td>
                      </tr>
                    </tbody>
                  </table>
                </div>

                <div class="vp-tome__section">
                  <span class="vp-tome__section-mark">❖</span>
                  <span class="vp-tome__section-label">Grundegenskaper</span>
                  <span class="vp-tome__section-mark">❖</span>
                </div>

                <div class="eg-grid">

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Styrka</div>
                    <p>Fysisk kraft. Används för att lyfta, knuffa, bryta, greppa, kasta och ta sig igenom hinder med rå styrka.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Genomslag</div><div class="eg-sub-desc">Slå igenom rustning, sköld eller guard.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Bärkraft</div><div class="eg-sub-desc">Avgöra hur mycket du kan bära.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Förflytta</div><div class="eg-sub-desc">Kasta, lyfta, knuffa eller sparka upp dörrar.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Brottas</div><div class="eg-sub-desc">Greppa, hålla fast och kontrollera någon.</div></div>
                    </div>
                  </div>

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Skicklighet</div>
                    <p>Kroppskontroll, precision och smidighet. Används för att skjuta, smyga, klättra, undvika fara eller hantera små detaljer.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Skytte</div><div class="eg-sub-desc">Träffa med pilbåge, kastvapen och andra distansattacker.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Fingerfärdighet</div><div class="eg-sub-desc">Dyrka lås, knyta rep, ficktjuveri och småarbete.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Ackuratess</div><div class="eg-sub-desc">Träffa en fiende som försöker undvika dig.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Akrobatik/smidighet</div><div class="eg-sub-desc">Akta sig, klättra, smyga och röra sig smidigt.</div></div>
                    </div>
                  </div>

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Tålighet</div>
                    <p>Fysisk och mental motståndskraft. Avgör hur mycket smärta, skräck, skador, trötthet och press du klarar av.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Mental tålighet</div><div class="eg-sub-desc">Rädsla, smärta, trauma och kallblodiga situationer.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Fysisk tålighet</div><div class="eg-sub-desc">Liv, kroppslig stryktålighet och skador.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Blockeringsförmåga</div><div class="eg-sub-desc">Blockera attacker.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Uthållighet</div><div class="eg-sub-desc">Springa länge, tåla hunger, törst och sömnbrist.</div></div>
                    </div>
                  </div>

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Intelligens</div>
                    <p>Kunskap, slutledning och problemlösning. Används för att förstå världen, dra slutsatser, känna igen fakta eller skapa lösningar.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Allmänbildning</div><div class="eg-sub-desc">Språk, naturkunskap, geografi och världskunskap.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Öga för detaljer</div><div class="eg-sub-desc">Iaktta omgivningen och upptäcka små avvikelser.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Logiskt tänkande</div><div class="eg-sub-desc">Förstå ledtrådar och lägga ihop information.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Uppfinningsrikedom</div><div class="eg-sub-desc">Bygga, laga, improvisera och skapa lösningar.</div></div>
                    </div>
                  </div>

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Klokhet</div>
                    <p>Intuition, fokus och reaktionsförmåga. Används för att agera snabbt, känna fara, ana lögner och uppfatta magi.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Snabbtänkthet</div><div class="eg-sub-desc">Initiativ och reaktionsförmåga.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Känna av fara</div><div class="eg-sub-desc">Ana hot, fara eller när något är fel.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Se igenom lögner</div><div class="eg-sub-desc">Avgöra om någon ljuger eller döljer något.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Magisk känsla</div><div class="eg-sub-desc">Känna av magi i platser, föremål och personer.</div></div>
                    </div>
                  </div>

                  <div class="vp-tome__card">
                    <div class="vp-tome__card-title"><span class="vp-tome__card-title-glyph">❦</span>Utstrålning</div>
                    <p>Närvaro, karisma och social påverkan. Används för att ljuga, övertala, inge förtroende, väcka känslor och påverka andra.</p>
                    <div class="eg-card-subs-label">Subegenskaper</div>
                    <div class="eg-card-subs">
                      <div class="eg-sub"><div class="eg-sub-name">Ljuga</div><div class="eg-sub-desc">Få andra att tro på dina lögner.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Övertala</div><div class="eg-sub-desc">Påverka andra med argument och resonemang.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Intryck</div><div class="eg-sub-desc">Hur andra uppfattar dig vid första mötet.</div></div>
                      <div class="eg-sub"><div class="eg-sub-name">Väcka känslor</div><div class="eg-sub-desc">Inspirera, förföra, peppa eller påverka emotionellt.</div></div>
                    </div>
                  </div>

                </div>

                <div class="vp-tome__section">
                  <span class="vp-tome__section-mark">❖</span>
                  <span class="vp-tome__section-label">Hur väljer man rätt subegenskap?</span>
                  <span class="vp-tome__section-mark">❖</span>
                </div>

                <p>Det viktiga är inte bara vad du försöker göra, utan hur du gör det. Beskriv handlingen tydligt, så avgör spelare och spelledare vilken subegenskap som passar bäst.</p>

                <div class="vp-tome__card">
                  <div class="vp-tome__card-title">
                    <span class="vp-tome__card-title-glyph">❦</span>
                    <span>Exempel</span>
                  </div>
                  <table class="vp-tome__pair-table">
                    <tbody>
                      <tr>
                        <td>Övertala med argument</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Utstrålning + Övertala</td>
                      </tr>
                      <tr>
                        <td>Övertala genom känslor</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Utstrålning + Väcka känslor</td>
                      </tr>
                      <tr>
                        <td>Ana att något är fel</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Klokhet + Känna av fara</td>
                      </tr>
                      <tr>
                        <td>Upptäcka en dold detalj</td>
                        <td class="vp-tome__pair-arrow">→</td>
                        <td>Intelligens + Öga för detaljer</td>
                      </tr>
                    </tbody>
                  </table>
                </div>

              </div>
            </div>

            <div class="tab-content" id="tab-spelarbok" style="display:none;">
                @await Html.PartialAsync("_RulesSpelarbok")
            </div>

            <div class="tab-content" id="tab-poangkostnader" style="display:none;">
                @await Html.PartialAsync("_RulesPoangkostnader")
            </div>

            <div class="tab-content" id="tab-adveniriska" style="display:none;">
                @await Html.PartialAsync("_RulesAdveniriska")
            </div>

            <div class="tab-content" id="tab-livstrid" style="display:none;">
                @await Html.PartialAsync("_RulesLivStrid")
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <script src="~/js/pages/rules.page.js" asp-append-version="true"></script>
    <script src="~/js/pages/adveniriska.subtabs.js" asp-append-version="true"></script>
}
