@page
@model Viaproxima.Web.Pages.CharacterListModel

@{
    ViewData["Title"] = "Karaktärslista";
}

@section Styles {
    <link rel="stylesheet" href="~/css/vp.theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/vp.base.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/characterSheet.layout.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/pages/characterList.css" asp-append-version="true" />
}

<div class="page">
    <div class="sheet sheet--list">
        <header class="sheet-header">
            <div>
                <div class="label">Viaproxima</div>
                <div class="value">Karaktärslista</div>
            </div>
        </header>

        <section class="sheet-column">
            <h2>Sparade karaktärer</h2>

            @if (Model.Characters.Count == 0)
            {
                <p class="hint">Inga sparade karaktärer ännu. Skapa en ny och tryck Spara.</p>
            }
            else
            {
                <ul style="margin:0; padding-left:0; list-style:none;">
                    @foreach (var c in Model.Characters)
                    {
                        var name = string.IsNullOrWhiteSpace(c.Name) ? "Namnlös" : c.Name;
                        var race = string.IsNullOrWhiteSpace(c.Race) ? "Okänd" : c.Race;

                        <li class="char-row">
                            <a class="char-row__link"
                               asp-page="/CharacterSheet"
                               asp-route-id="@c.Id"
                               target="_blank"
                               rel="noopener">
                                @name <span class="char-row__race">· @race</span>
                            </a>

                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-id="@c.Id"
                                  style="margin:0;">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn-delete"
                                        onclick="return confirm('Ta bort den här karaktären?');">
                                    Ta bort
                                </button>
                            </form>
                        </li>
                    }
                </ul>
            }
        </section>

        <section class="sheet-column">
            <h2>Ny karaktär</h2>
            <a class="btn-small" asp-page="/CharacterSheet" target="_blank" rel="noopener">
                Öppna tomt ark
            </a>
        </section>
    </div>
</div>
