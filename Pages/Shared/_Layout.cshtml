<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Viaproxima.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Viaproxima.Web.styles.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&family=Libre+Baskerville:wght@400;700&display=swap" rel="stylesheet">

    @await RenderSectionAsync("Styles", required: false)

</head>

<body>
    <header>
        <nav class="top-nav">
            <a asp-area="" asp-page="/Index">Hem</a>
            <a asp-page="/CharacterList">Karaktärer</a>
            <a asp-page="/Aventyrsdagbok/Index">Äventyrsdagbok</a>
            <a asp-page="/Rules">Regler</a>
            <a asp-page="/FloraFauna">Världen</a>
            <a asp-page="/MerchantGenerator">Verktyg</a>
            <div class="spacer"></div>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <button type="button" id="logoutBtn">Logga ut (@User.Identity.Name)</button>
            }
            else
            {
                <a asp-page="/Login">Log In</a>
            }
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

 
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>